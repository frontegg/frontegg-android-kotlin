<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/admin_portal_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <WebView
        android:id="@+id/admin_portal_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="false" />

    <!--
        Centered progress indicator shown over the WebView during the initial
        WebView load. We defer webView.loadUrl until the bridged refresh cookie
        has been written into CookieManager so the portal recognizes the
        session — without this indicator the user sees a blank white surface
        for the duration of that initial paint.

        Hidden in code on the WebViewClient's first onPageFinished.
    -->
    <ProgressBar
        android:id="@+id/admin_portal_loader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true" />

</FrameLayout>
